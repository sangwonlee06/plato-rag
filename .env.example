# --- Database ---
# Async URL (used by the FastAPI app at runtime)
PLATO_RAG_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/plato_rag
# Sync URL (used by Alembic for migrations)
PLATO_RAG_DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/plato_rag

# --- Embedding (OpenAI) ---
# Required. Used to embed chunks during ingestion and queries during retrieval.
PLATO_RAG_OPENAI_API_KEY=sk-...
PLATO_RAG_EMBEDDING_MODEL=text-embedding-3-large
PLATO_RAG_EMBEDDING_DIMENSIONS=3072

# --- Generation (Anthropic) ---
# Required. Used to generate grounded answers from retrieved chunks.
PLATO_RAG_ANTHROPIC_API_KEY=sk-ant-...
PLATO_RAG_GENERATION_MODEL=claude-sonnet-4-20250514
PLATO_RAG_GENERATION_MAX_TOKENS=2048

# --- Service ---
PLATO_RAG_API_VERSION=1.0.0
PLATO_RAG_DEBUG=false
PLATO_RAG_LOG_LEVEL=INFO
# Set to public for any public-facing deployment.
PLATO_RAG_DEPLOYMENT_SCOPE=local
# Public-safe collection allowlist. Keep sep out of this list.
PLATO_RAG_PUBLIC_ALLOWED_COLLECTIONS=platonic_dialogues,aristotle_corpus,cartesian_meditations,hume_enquiry,iep
# Local-only SEP must stay disabled in public deployments.
PLATO_RAG_ENABLE_LOCAL_ONLY_SEP=false
PLATO_RAG_LOCAL_ONLY_ALLOWED_COLLECTIONS=sep
PLATO_RAG_LOCAL_ONLY_MANIFEST_PATH=local_only/sep/corpus_seed.local.json
PLATO_RAG_FAIL_START_ON_RESTRICTED_CONFIG=true
